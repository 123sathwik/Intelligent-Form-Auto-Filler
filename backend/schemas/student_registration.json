{
  "form_type": "Student Registration",
  "icon": "School",
  "description": "Student enrollment and registration form",
  "sections": [
    {
      "id": "student_details",
      "title": "Student Details",
      "icon": "User",
      "fields": [
        { "id": "name", "label": "Student Name", "type": "text", "required": true, "placeholder": "Vamsi Krishna", "entity_keys": ["name", "person_name"] },
        { "id": "roll_number", "label": "Roll Number", "type": "text", "required": false, "placeholder": "21CS001", "entity_keys": ["roll_number"] },
        { "id": "registration_number", "label": "Registration Number", "type": "text", "required": false, "placeholder": "REG-2024-001", "entity_keys": ["registration_number"] },
        { "id": "dob", "label": "Date of Birth", "type": "date", "required": true, "placeholder": "YYYY-MM-DD", "entity_keys": ["dob", "date_of_birth"] },
        { "id": "gender", "label": "Gender", "type": "dropdown", "required": true, "options": ["Male", "Female", "Other"], "entity_keys": ["gender"] },
        { "id": "aadhaar_number", "label": "Aadhaar Number", "type": "text", "required": false, "placeholder": "1234 5678 9012", "entity_keys": ["aadhaar_number"] },
        { "id": "father_name", "label": "Father's Name", "type": "text", "required": false, "placeholder": "Father's full name", "entity_keys": ["father_name"] },
        { "id": "mother_name", "label": "Mother's Name", "type": "text", "required": false, "placeholder": "Mother's full name", "entity_keys": ["mother_name"] }
      ]
    },
    {
      "id": "academic_details",
      "title": "Academic Details",
      "icon": "GraduationCap",
      "fields": [
        { "id": "department", "label": "Department", "type": "text", "required": true, "placeholder": "Computer Science", "entity_keys": ["branch"] },
        { "id": "program", "label": "Program / Degree", "type": "text", "required": true, "placeholder": "B.Tech", "entity_keys": ["degree"] },
        { "id": "semester", "label": "Semester / Year", "type": "dropdown", "required": false, "options": ["1st", "2nd", "3rd", "4th", "5th", "6th", "7th", "8th"], "entity_keys": [] },
        { "id": "cgpa", "label": "CGPA", "type": "text", "required": false, "placeholder": "9.4", "entity_keys": ["cgpa"] },
        { "id": "college", "label": "College Name", "type": "text", "required": false, "placeholder": "ABC Engineering College", "entity_keys": ["college"] },
        { "id": "university", "label": "University", "type": "text", "required": false, "placeholder": "Osmania University", "entity_keys": ["university"] }
      ]
    },
    {
      "id": "contact_details",
      "title": "Contact Details",
      "icon": "Mail",
      "fields": [
        { "id": "email", "label": "Email Address", "type": "email", "required": true, "placeholder": "student@college.edu", "entity_keys": ["email"] },
        { "id": "phone", "label": "Phone Number", "type": "phone", "required": true, "placeholder": "+91 9876543210", "entity_keys": ["phone", "phone_number"] },
        { "id": "address", "label": "Residential Address", "type": "textarea", "required": false, "placeholder": "Full address", "entity_keys": ["address"] },
        { "id": "city", "label": "City", "type": "text", "required": false, "placeholder": "Hyderabad", "entity_keys": ["city"] },
        { "id": "state", "label": "State", "type": "text", "required": false, "placeholder": "Telangana", "entity_keys": ["state"] },
        { "id": "pincode", "label": "Pincode", "type": "text", "required": false, "placeholder": "500034", "entity_keys": ["pincode"] }
      ]
    }
  ]
}
