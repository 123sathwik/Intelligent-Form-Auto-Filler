{
  "form_type": "Bank KYC",
  "icon": "Landmark",
  "description": "Bank Know Your Customer (KYC) verification form",
  "sections": [
    {
      "id": "account_holder",
      "title": "Account Holder Details",
      "icon": "User",
      "fields": [
        { "id": "name", "label": "Full Name", "type": "text", "required": true, "placeholder": "Vamsi Krishna", "entity_keys": ["name", "person_name"] },
        { "id": "dob", "label": "Date of Birth", "type": "date", "required": true, "placeholder": "YYYY-MM-DD", "entity_keys": ["dob", "date_of_birth"] },
        { "id": "gender", "label": "Gender", "type": "dropdown", "required": false, "options": ["Male", "Female", "Other"], "entity_keys": ["gender"] },
        { "id": "nationality", "label": "Nationality", "type": "text", "required": false, "placeholder": "Indian", "entity_keys": ["nationality"] },
        { "id": "father_name", "label": "Father's Name", "type": "text", "required": false, "placeholder": "Father's full name", "entity_keys": ["father_name"] },
        { "id": "mother_name", "label": "Mother's Name", "type": "text", "required": false, "placeholder": "Mother's full name", "entity_keys": ["mother_name"] },
        { "id": "email", "label": "Email Address", "type": "email", "required": true, "placeholder": "john@example.com", "entity_keys": ["email"] },
        { "id": "phone", "label": "Mobile Number", "type": "phone", "required": true, "placeholder": "+91 9876543210", "entity_keys": ["phone", "phone_number"] },
        { "id": "address", "label": "Current Address", "type": "textarea", "required": true, "placeholder": "Full address", "entity_keys": ["address"] },
        { "id": "city", "label": "City", "type": "text", "required": false, "placeholder": "Hyderabad", "entity_keys": ["city"] },
        { "id": "state", "label": "State", "type": "text", "required": false, "placeholder": "Telangana", "entity_keys": ["state"] },
        { "id": "pincode", "label": "Pincode", "type": "text", "required": false, "placeholder": "500034", "entity_keys": ["pincode"] }
      ]
    },
    {
      "id": "document_verification",
      "title": "Document Verification",
      "icon": "Shield",
      "fields": [
        { "id": "aadhaar_number", "label": "Aadhaar Number", "type": "text", "required": false, "placeholder": "1234 5678 9012", "entity_keys": ["aadhaar_number"] },
        { "id": "pan_number", "label": "PAN Number", "type": "text", "required": false, "placeholder": "ABCDE1234F", "entity_keys": ["pan_number"] },
        { "id": "passport_number", "label": "Passport Number", "type": "text", "required": false, "placeholder": "Z1234567", "entity_keys": ["passport_number"] },
        { "id": "occupation", "label": "Occupation", "type": "dropdown", "required": false, "options": ["Salaried", "Self Employed", "Business", "Student", "Retired", "Other"], "entity_keys": [] },
        { "id": "annual_income", "label": "Annual Income", "type": "text", "required": false, "placeholder": "₹ 8,00,000", "entity_keys": [] }
      ]
    }
  ]
}
