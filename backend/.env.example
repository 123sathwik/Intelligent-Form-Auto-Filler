# --- System Environment ---
ENV=development
DEBUG=true

# --- Server Bindings ---
HOST=0.0.0.0
PORT=8000
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Security Configuration ---
JWT_SECRET=your-super-secret-jwt-signing-key-for-local-development
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autofiller

# --- Firebase Service Integration ---
# Path to Firebase Admin SDK json credentials
FIREBASE_SERVICE_ACCOUNT_JSON=firebase/service-account.json

# --- AI & Gemini Service Integration ---
GEMINI_API_KEY=your-gemini-api-key-here
