# ==========================================
# Intelligent Form Auto-Filler Env Template
# ==========================================

# --- System Environment ---
ENV=development
DEBUG=true

# --- Backend Config (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
SECRET_KEY=generate-a-secure-secret-key-here-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database Config ---
# For PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autofiller
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- Firebase Config ---
# Client Configurations
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
# Server (Admin SDK) Configurations
FIREBASE_SERVICE_ACCOUNT_JSON=firebase/service-account.json

# --- OCR Engine Configurations ---
OCR_ENGINE=tesseract # or paddleocr, google_vision, aws_textract
TESSERACT_CMD_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# External OCR Credentials if applicable
GOOGLE_APPLICATION_CREDENTIALS=config/google-creds.json
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# --- ML Pipeline configurations ---
ML_MODELS_PATH=models/
OCR_CONFIDENCE_THRESHOLD=0.70
NER_MODEL_NAME=dbmdz/bert-large-cased-finetuned-conll03-english
MAPPING_CONFIDENCE_THRESHOLD=0.65
