# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Don't check virtual environment files
[.venv/**]
insert_final_newline = false
trim_trailing_whitespace = false

[node_modules/**]
insert_final_newline = false
trim_trailing_whitespace = false

# Matches all files
[*]
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# JavaScript / TypeScript / JSON styling
[*.{js,jsx,ts,tsx,json}]
indent_style = space
indent_size = 2

# Python styling (PEP 8)
[*.py]
indent_style = space
indent_size = 4

# Markdown formatting
[*.md]
trim_trailing_whitespace = false
